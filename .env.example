NODE_ENV=development
PORT=3003
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=document_db

STORAGE_DRIVER=s3
LOCAL_STORAGE_PATH=./uploads
