S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

CLAMAV_HOST=clamav
CLAMAV_PORT=3310

UPLOAD_MAX_SIZE=524288000

CORS_ORIGIN=*
