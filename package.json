{
  "name": "document-service",
  "version": "1.0.0",
  "description": "Servicio de documentos del ecosistema CRM (Node + TypeScript + Hono + MySQL + S3/MinIO).",
  "license": "UNLICENSED",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/s3-request-presigner": "^3.758.0",
    "@hono/node-server": "^1.19.14",
    "@hono/zod-validator": "^0.4.1",
    "dotenv": "^16.4.7",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "mysql2": "^3.11.5",
    "sequelize": "^6.37.5",
    "sequelize-cli": "^6.6.2",
    "sharp": "^0.33.2",
    "uuid": "^11.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "commonjs"
}
